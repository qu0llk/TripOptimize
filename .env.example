# Учётные данные резидентного прокси (обязательны для работы скрапера).
# Без валидного прокси скрапер откажется запускаться.
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# Строка подключения к PostgreSQL (обязательна для Модуля 3 — БД).
# ВАЖНО: используется асинхронный драйвер asyncpg, поэтому URL обязан
# начинаться с префикса postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tripoptimize

# Токен Telegram-бота (обязателен для Модуля 6 — бота). Получите у @BotFather.
# Прочие модули (API, скрапер) работают и без него.
TELEGRAM_BOT_TOKEN=

# HTTP-прокси для Telegram-бота (опционально, только для бота).
# Используйте, если api.telegram.org недоступен напрямую (например, в России).
# Формат: http://host:port  или  http://user:pass@host:port
# Скрапер использует отдельный резидентный прокси (PROXY_*) — не смешивайте.
TELEGRAM_PROXY_URL=

# Параметры запуска веб-приложения (используются в команде uvicorn).
APP_HOST=0.0.0.0
APP_PORT=8000

# Опциональные параметры запуска браузера.
# HEADLESS=true — запуск без графического окна.
HEADLESS=true

# Таймаут навигации Playwright в миллисекундах.
NAV_TIMEOUT_MS=45000

# «Окно добора» (мс) после первой партии результатов: по его истечении
# страница принудительно закрывается, чтобы не оплачивать «хвост» трафика.
# Меньше значение — меньше трафика, но выше риск недобрать поздние предложения.
RESULTS_GRACE_MS=3000
